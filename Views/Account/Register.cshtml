﻿@{
Layout = null;
}
@model Mom_Project.Models.UserModel

@{
    ViewData["Title"] = "Register";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register | MOM System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- YOUR register CSS -->
    <link href="~/assets/css/registerStyle.css" rel="stylesheet" />
</head>
<body>

    <div class="auth-wrapper">
        <div class="auth-card">
            
            <!-- Header -->
            <div class="text-center mb-4">
                <div class="logo-icon">
                    <i class="bi bi-person-plus"></i>
                </div>
                <h6 class="brand-name">Join MOM System</h6>
                <h4 class="fw-bold">Create Account</h4>
                <p class="text-muted small">
                    Join the meeting management system to organize and track meetings efficiently
                </p>
            </div>

            <!-- Form -->
            <form asp-action="Register" method="post">
                <div class="row g-3">

                    <div class="col-md-6 position-relative">
                        <label asp-for="UserName" class="form-label small">Username</label>
                        <input asp-for="UserName" type="text" class="form-control custom-input" placeholder="Username">
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        <i class="bi bi-person input-icon"></i>
                        <small class="text-muted">3–50 characters required</small>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label asp-for="Email" class="form-label small">Email</label>
                            <input asp-for="Email" type="text" class="form-control custom-input" placeholder="Email">
                                <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label asp-for="Password" class="form-label small">Password</label>
                        <input asp-for="Password" type="password" class="form-control custom-input" placeholder="Password">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                        <i class="bi bi-lock input-icon"></i>
                        <small class="text-muted">Minimum 6 characters</small>
                    </div>

                    <div class="col-md-6 position-relative">
                        <label asp-for="ConfirmPassword" class="form-label small">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control custom-input" placeholder="Confirm Password">
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        <i class="bi bi-lock-fill input-icon"></i>
                    </div>

                                    <div class="col-md-6 position-relative">
                                        <label asp-for="MobileNo" class="form-label small">Mobile Number</label>
                                        <input asp-for="MobileNo" type="text" class="form-control custom-input" placeholder="Number">
                                            <span asp-validation-for="MobileNo" class="text-danger"></span>
                                            <i class="bi bi-person input-icon"></i>
                                            <small class="text-muted">3–50 characters required</small>
                                        </div>

                                        <div class="col-md-6 position-relative">
                                            <label asp-for="Address" class="form-label small">Username</label>
                                            <textarea asp-for="Address" type="text" class="form-control custom-input" placeholder="Address"></textarea>
   
                                                <span asp-validation-for="Address" class="text-danger"></span>
                                                <i class="bi bi-person input-icon"></i>
                                                <small class="text-muted">3–50 characters required</small>
                                            </div>
                </div>

                <button type="submit" class ="btn text-white w-100 mt-4" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                    <i class="bi bi-person-check me-1"></i> Create Account
                </button>

                <p class="text-center small mt-3 mb-0">
                    Already have an account?
                    <a asp-action="Login" class="fw-semibold text-decoration-none">Sign in here</a>
                </p>
            </form>

        </div>
    </div>

</body>
</html>

                @section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
                    }
                }
