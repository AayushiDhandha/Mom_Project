@model List<Mom_Project.Models.MeetingsModel>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Meeting Management</h2>
        <div class="sub-text">Schedule and manage organizational meetings</div>
    </div>

    <div>
        <a asp-controller="Meetings"
               asp-action="MeetingsAddEdit"
               class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-plus-circle"></i> Add New Meeting
        </a>

        <a asp-controller="Meetings" asp-action="ExportToExcel" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export
        </a>
    </div>
</div>

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <form asp-controller="Meetings" asp-action="MeetingsList" method="post">
                <div class="card border-0 shadow-lg rounded-4 mb-4">
                    <div class="card-header text-white rounded-top-4"
                         style="background: linear-gradient(170deg, #1e3a8a 0%, #2563eb 85%, #3b82f6 100%);">
                        <h6 class="mb-0">
                            <i class="bi bi-funnel me-2"></i> Search & Filters
                        </h6>
                    </div>

                    <div class="card-body p-4">
                        <div class="row align-items-end">
                            <div class="row mb-3">

                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Meeting Type</label>
                                    <div class="input-group">
                                        <select name="MeetingTypeID" class="form-select" asp-items="ViewBag.MeetingTypeList">
                                            <option selected value="">All Types</option>
                                            
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                <label class="form-label fw-semibold">Department</label>
                                    <div class="input-group">
                                        <select name="DepartmentID" class="form-select" asp-items="ViewBag.MeetingTypeList" >
                                            <option selected value="">All Departments</option>
                                           
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                <label class="form-label fw-semibold">Venue</label>
                                    <div class="input-group">
                                        <select name="MeetingVenueID" class="form-select" asp-items="ViewBag.MeetingTypeList">
                                            <option selected value="">All Venues</option>
                                            
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Search</label>
                                    <div class="input-group">
                                        <input type="text" name="SearchText" id="SearchText" class="form-control"
                                               value="@ViewBag.SearchText" placeholder="Search meetings...">
                                        <span class="input-group-text bg-white">
                                            <i class="bi bi-search"></i>
                                        </span>
                                    </div>
                                </div>

                            </div>

                            <div class="row align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Start Date</label>
                                    <input type="date" class="form-control">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">End Date</label>
                                    <input type="date" class="form-control">
                                </div>

                                <div class="col-md-3">
                                    <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                                        <i class="bi bi-funnel me-1"></i> Apply Filters
                                    </button>
                                </div>

                                <div class="col-md-3">
                                    <a asp-controller="Meetings" asp-action="MeetingsList" class="btn btn-secondary ms-2">
                                        <i class="fas fa-undo"></i> Clear
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </form>

            <div class="card table-card">

                <div class="table-header-gradient">
                    <i class="bi bi-tag"></i> Meetings List
                </div>

                <div class="table-responsive">


                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
                        <table class="table  table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Meeting Date</th>
                                    <th>Meeting Description</th>
                                    <th>Document Path</th>
                                    <th>Is Cancelled</th>
                                    <th>Cancellation Date Time</th>
                                    <th>Cancellation Reason</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var meetings in Model)
                                {
                                    <tr>
                                        <td>@meetings.MeetingID</td>
                                        <td>@meetings.MeetingDate</td>
                                        <td>@meetings.MeetingDescription</td>
                                        <td>@meetings.DocumentPath</td>
                                        <td>@meetings.IsCancelled</td>
                                        <td>@meetings.CancellationDateTime</td>
                                        <td>@meetings.CancellationReason</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-action="MeetingsAddEdit"
                                               asp-route-id="@meetings.MeetingID"
                                            title="Edit"
                                            style=" width:36px;
                                               height:36px;
                                               border:1.5px solid #0d6efd;
                                               border-radius:6px;
                                               display:flex;
                                               align-items:center;
                                               justify-content:center;
                                               color:#0d6efd;
                                               text-decoration:none;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            
                                            <!-- Delete Button -->
                                            <a asp-action="DeleteMeetings"
                                                   asp-route-id="@meetings.MeetingID"
                                                   class="delete-link"
                                                   title="Delete"
                                                   style="
                                                width:36px;
                                                height:36px;
                                                border:1.5px solid #dc3545;
                                                border-radius:6px;
                                                display:flex;
                                                align-items:center;
                                                justify-content:center;
                                                color:#dc3545;
                                                text-decoration:none;
                                                ">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                           

                                            <!-- Visible eye button-->
                                            <a asp-controller="Attendance"
                                                   asp-action="AttendanceList"
                                                 
                                                   title="View"
                                                   style=" width:36px;
                                                height:36px;
                                                border:1.5px solid #0d6efd;
                                                border-radius:6px;
                                                display:flex;
                                                align-items:center;
                                                justify-content:center;
                                                color:#0d6efd;
                                                text-decoration:none;">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                             }
                            </tbody>
                        </table>
                    }
                    <!-- End Table with stripped rows -->

                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                document.querySelectorAll('.delete-link').forEach(link => {
                link.addEventListener('click', function (e) {
                e.preventDefault();

                const url = this.href;

                Swal.fire({
                title: 'Are you sure?',
                text: "This record will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                if (result.isConfirmed) {
                window.location.href = url;
                }
                });
                });
                });
            </script>

            @if (TempData["Success"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["Success"]',
                        showConfirmButton: false,
                        timer: 2000
                    });
                </script>
            }

            @if (TempData["Error"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'error',
                        title: 'Delete Failed',
                        text: '@TempData["Error"]'
                    });
                </script>
            }

        </div>
    </div>

    
</section>

