@model List<MeetingMemberModel>
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Meetings Members</h2>
        <div class="sub-text">Manage Meeting member</div>
    </div>

    <div>
        <a asp-controller="MeetingMember"
               asp-action="MeetingMemberAddEdit"
               class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-plus-circle"></i> Add Meeting Member
        </a>

        <a asp-controller="MeetingMember" asp-action="ExportToExcel" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export
        </a>
    </div>
</div>

<!-- Search Box -->
<div class="search-card mb-4">
    <form asp-controller="MeetingMember" asp-action="MeetingMemberList" method="post">
        <label class="form-label">Search Meeting Member</label>

        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="SearchText" id="SearchText" class="form-control"
                           value="@ViewBag.SearchText" placeholder="Enter member name...">
                    <button type="submit" class="btn btn-purple">Search</button>
                    <a asp-controller="MeetingMember" asp-action="MeetingMemberList" class="btn btn-secondary ms-2">
                        <i class="fas fa-undo"></i> Clear
                    </a>
                </div>
            </div>

            <div class="col-md-4 text-end mt-2 mt-md-0">
                <small class="text-muted">Total Records:</small>
                <div class="fw-bold">@Model.Count</div>
            </div>
        </div>
    </form>
</div>

<div class="card table-card">

    <div class="table-header-gradient">
        <i class="bi bi-tag"></i> Meeting Membeer List
    </div>

    <div class="table-responsive">

                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
            <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Present</th>
                                    <th>Remarks</th>
                                    <th>Action</th>
                                </tr>
                            </thead>



                            <tbody>
                                @foreach (var meetingMember in Model)
                                {

                                    <tr>
                                      
                                        <td>@meetingMember.MeetingMemberID</td>
                                        <td>@meetingMember.IsPresent</td>
                                        <td>@meetingMember.Remarks</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-action="MeetingMemberAddEdit"
                                                   asp-route-id="@meetingMember.MeetingMemberID"
                                                   title="Edit"
                                                   style="
                                                width:36px;
                                                height:36px;
                                                border:1.5px solid #0d6efd;
                                                border-radius:6px;
                                                display:flex;
                                                align-items:center;
                                                justify-content:center;
                                                color:#0d6efd;
                                                text-decoration:none;
                                                ">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="DeleteMeetingMember"
                                                   asp-route-id="@meetingMember.MeetingMemberID"
                                                   class="delete-link"
                                                   title="Delete"
                                                   style="
                                                width:36px;
                                                height:36px;
                                                border:1.5px solid #dc3545;
                                                border-radius:6px;
                                                display:flex;
                                                align-items:center;
                                                justify-content:center;
                                                color:#dc3545;
                                                text-decoration:none;
                                                ">
                                                <i class="bi bi-trash"></i>
                                            </a>
                               
                                

                                        </td>

                                    </tr>

                                }
                            </tbody>
                        </table>
                    }
                  
                    <!-- End Table with stripped rows -->

                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
                document.querySelectorAll('.delete-link').forEach(link => {
                link.addEventListener('click', function (e) {
                e.preventDefault();

                const url = this.href;

                Swal.fire({
                title: 'Are you sure?',
                text: "This record will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                if (result.isConfirmed) {
                window.location.href = url;
                }
                });
                });
                });
            </script>

            @if (TempData["Success"] != null)
            {
                <script>
                    Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: '@TempData["Success"]',
                    showConfirmButton: false,
                    timer: 2000
                    });
                </script>
            }

            @if (TempData["Error"] != null)
            {
                <script>
                    Swal.fire({
                    icon: 'error',
                    title: 'Delete Failed',
                    text: '@TempData["Error"]'
                    });
                </script>
            }
        </div>
    </div>
</section>