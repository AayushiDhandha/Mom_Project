@model List<MeetingMemberModel>

<div class="pagetitle">
    <h1>Meeting Members</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="MeetingMember" asp-action="MeetingMemberList"><i class="bi bi-house"></i></a></li>
            <li class="breadcrumb-item active">Meeting Member List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->

<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-people-fill"></i>
                            Meeting Member List
                        </h5>

                        <a asp-controller="MeetingMember"
                           asp-action="MeetingMemberAddEdit"
                           class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                            <i class="bi bi-plus-lg"></i> Add Members
                        </a>
                    </div>


                     @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
                        <table class="table datatable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Present</th>
                                    <th>Remarks</th>
                                    <th>Action</th>
                                </tr>
                            </thead>



                            <tbody>
                            @foreach (var meetingMember in Model)
                                {
                                    @* <tr>
                                        <td>@meetingMember.MeetingMemberID</td>
                                        <td>@meetingMember.IsPresent</td>
                                        <td>@meetingMember.Remarks</td>
                                        @* <td>
                                            <button class="btn btn-success"
                                            onclick="toggleAttendance(this)">
                                                Present
                                            </button>
                                        </td> 
                                             
                                    </tr> *@

                                    <tr>

                                        <td>@meetingMember.MeetingMemberID</td>
                                        <td>@meetingMember.IsPresent</td>
                                        <td>@meetingMember.Remarks</td>
                            <td class="d-flex gap-2 align-items-center">

                                <!-- Edit Button -->
                                            <a asp-action="DeleteMeetingMember"
                                               asp-route-id="@meetingMember.MeetingMemberID"
                                   title="Edit"
                                   style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #0d6efd;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#0d6efd;
                                                       text-decoration:none;
                                                ">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <!-- Delete Button -->
                                <a asp-action="DeleteMeetingMember"
                                   asp-route-id="@meetingMember.MeetingMemberID"
                                   title="Delete"
                                   style="
                                                               width:36px;
                                                               height:36px;
                                                               border:1.5px solid #dc3545;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#dc3545;
                                                               text-decoration:none;
                                                            ">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </td>

                        </tr>

                               }
                            </tbody>
                        </table>
                    }
                    <!-- ✅ SCRIPT MUST BE WRITTEN ONLY ONCE -->
                    <script>
                        function toggleAttendance(btn) {
                            if (btn.innerText === "Present") {
                                btn.innerText = "Absent";
                                btn.classList.remove("btn-success");
                                btn.classList.add("btn-danger");
                            } else {
                                btn.innerText = "Present";
                                btn.classList.remove("btn-danger");
                                btn.classList.add("btn-success");
                            }
                        }
                    </script>

                    <!-- End Table with stripped rows -->

                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            @if (TempData["Success"] != null)
            {
                <script>
                        Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["Success"]',
                        showConfirmButton: false,
                        timer: 2000
                    });
                </script>
            }

            @if (TempData["Error"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'error',
                        title: 'Delete Failed',
                        text: '@TempData["Error"]'
                    });
                </script>
            }
        </div>
    </div>
</section>