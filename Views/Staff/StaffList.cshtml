@model List<StaffModel>
<div class="pagetitle">
    <h1>Staff List</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Staff" asp-action="StaffList"><i class="bi bi-house"></i></a></li>
            <li class="breadcrumb-item active">Staff List</li>
        </ol>
    </nav>
</div><!-- End Page Title -->


<section class="section">
    <div class="row">
        <div class="col-lg-12">

            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0"><i class="bi-person-vcard me-2"></i>Staff List</h5>

                        <a asp-controller="Staff"
                           asp-action="StaffAddEdit"
                           class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
                            <i class="bi bi-plus-lg"></i> Add Staff
                        </a>
                    </div>


                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
                        <table class="table datatable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Staff Name</th>
                                    <th>Mobile No </th>
                                    <th>Email Address</th>
                                    <th>Remarks</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var staff in Model)
                                {
                                    <tr>
                                        <td>@staff.StaffID</td>
                                        <td>@staff.StaffName</td>
                                        <td>@staff.MobileNo</td>
                                        <td>@staff.EmailAddress</td>
                                        <td>@staff.Remarks</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-controller="Staff"
                                                asp-action="StaffAddEdit"
                                                asp-route-id="@staff.StaffID"
                                            title="Edit"
                                            style="
                                               width:36px; 
                                               height:36px;
                                               border:1.5px solid #0d6efd;
                                               border-radius:6px;
                                               display:flex;
                                               align-items:center;
                                               justify-content:center;
                                               color:#0d6efd;
                                               text-decoration:none;
                                            ">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-controller="Staff"
                                                asp-action="DeleteStaff"
                                               asp-route-id="@staff.StaffID"
                                            title="Delete"
                                            style="
                                               width:36px;
                                               height:36px;
                                               border:1.5px solid #dc3545;
                                               border-radius:6px;
                                               display:flex;
                                               align-items:center;
                                               justify-content:center;
                                               color:#dc3545;
                                               text-decoration:none;
                                            ">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </td>

                                    </tr>
                                    
                                }
                            </tbody>
                        </table>
                    }
                    <!-- End Table with stripped rows -->

                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            @if (TempData["Success"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["Success"]',
                        showConfirmButton: false,
                        timer: 2000
                    });
                </script>
            }

            @if (TempData["Error"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'error',
                        title: 'Delete Failed',
                        text: '@TempData["Error"]'
                    });
                </script>
            }
        </div>
    </div>
</section>