@model List<DepartmentModel>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Department</h2>
        <div class="sub-text">Manage organizational departments and their staff members</div>
    </div>

    <div>
        <a asp-controller="Department"
           asp-action="DepartmentAddEdit"
           class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-plus-circle"></i> Add Department
        </a>

        <a asp-controller="Department" asp-action="ExportToExcel" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export Department Data to Excel
        </a>
    </div>
</div>

<div class="search-card mb-4">
    <form asp-controller="Department" asp-action="Index" method="post">
    <div class="row align-items-center">
       
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search"></i>
                </span>
                
                <input type="text" name="SearchText" id="SearchText" class="form-control"
                       value="@ViewBag.SearchText" placeholder="Search Departments...">
                <button type="submit" class="btn btn-purple">Search</button>
                <a asp-controller="Department" asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="fas fa-undo"></i> Clear
                </a>
            </div>
        </div>
        

        <div class="col-md-4 text-end mt-2 mt-md-0">
            <small class="text-muted">Total Department:</small>
            <div class="fw-bold">@Model.Count</div>
        </div>
       
    </div>
    </form>
</div>

<div class="card table-card">

    <div class="table-header-gradient">
        <i class="bi bi-tag"></i> Meeting Types List
    </div>

    <div class="table-responsive">
        @if (Model != null && Model.Count > 0)
        {
            <table class="table table-hover mb-0">

                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Department Name </th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var department in Model)
                    {
                        <tr>

                            <td>@department.DepartmentID</td>
                            <td>@department.DepartmentName</td>
                            <td class="d-flex gap-2 align-items-center">

                                <!-- Edit Button -->
                                <a asp-action="DepartmentAddEdit"
                                   asp-route-id="@department.DepartmentID"
                                   title="Edit"
                                   style="
                                                       width:36px;
                                                       height:36px;
                                                       border:1.5px solid #0d6efd;
                                                       border-radius:6px;
                                                       display:flex;
                                                       align-items:center;
                                                       justify-content:center;
                                                       color:#0d6efd;
                                                       text-decoration:none;
                                                ">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <!-- Delete Button -->
                                <a asp-action="DeleteDepartment"
                                   asp-route-id="@department.DepartmentID"
                                   title="Delete"
                                   style="
                                                               width:36px;
                                                               height:36px;
                                                               border:1.5px solid #dc3545;
                                                               border-radius:6px;
                                                               display:flex;
                                                               align-items:center;
                                                               justify-content:center;
                                                               color:#dc3545;
                                                               text-decoration:none;
                                                            ">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </td>

                        </tr>


                    }
                </tbody>
            </table>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                showConfirmButton: false,
                timer: 2000
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Delete Failed',
                text: '@TempData["Error"]'
            });
        </script>
    }
</div>

