@model List<MeetingVenueModel>

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="page-title">Meeting Venues</h2>
        <div class="sub-text">Manage meeting rooms and virtual meeting locations</div>
    </div>

    <div>
        <a asp-controller="MeetingVenue"
               asp-action="MeetingVenueAddEdit"
               class="btn text-white" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-plus-circle"></i> Add Venue
        </a>

        <a asp-controller="MeetingVenue" asp-action="ExportToExcel" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export
        </a>
    </div>
</div>

<!-- Search Box -->
<div class="search-card mb-4">
    <form asp-controller="MeetingVenue" asp-action="MeetingVenueList" method="post">
    <label class="form-label">Search Meeting Venue</label>

    <div class="row align-items-center">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search"></i>
                </span>
                    <input type="text" name="SearchText" id="SearchText" class="form-control"
                           value="@ViewBag.SearchText" placeholder="Enter meeting venue name...">
                <button type="submit" class="btn btn-purple">Search</button>
                    <a asp-controller="MeetingVenue" asp-action="MeetingVenueList" class="btn btn-secondary ms-2">
                        <i class="fas fa-undo"></i> Clear
                    </a>
            </div>
        </div>

        <div class="col-md-4 text-end mt-2 mt-md-0">
            <small class="text-muted">Total Records:</small>
            <div class="fw-bold">@Model.Count</div>
        </div>
    </div>
    </form>
</div>

<div class="card table-card">

    <div class="table-header-gradient">
        <i class="bi bi-tag"></i> Meeting Venue List
    </div>

    <div class="table-responsive">
                    @if (Model != null && Model.Count > 0)
                    {
                        <!-- Table with stripped rows -->
            <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>MeetingVenue Name </th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var meetingVenue in Model)
                                {
                                    <tr>
                                        <td>@meetingVenue.MeetingVenueID</td>
                                        <td>@meetingVenue.MeetingVenueName</td>
                                        <td class="d-flex gap-2 align-items-center">

                                            <!-- Edit Button -->
                                            <a asp-action="MeetingVenueAddEdit"
                                               asp-route-id="@meetingVenue.MeetingVenueID"
                                            title="Edit"
                                            style="
                                               width:36px;
                                               height:36px;
                                               border:1.5px solid #0d6efd;
                                               border-radius:6px;
                                               display:flex;
                                               align-items:center;
                                               justify-content:center;
                                               color:#0d6efd;
                                               text-decoration:none;
                                            ">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <!-- Delete Button -->
                                            <a asp-action="DeleteMeetingVenue"
                                               asp-route-id="@meetingVenue.MeetingVenueID"
                                            title="Delete"
                                            style="
                                               width:36px;
                                               height:36px;
                                               border:1.5px solid #dc3545;
                                               border-radius:6px;
                                               display:flex;
                                               align-items:center;
                                               justify-content:center;
                                               color:#dc3545;
                                               text-decoration:none;
                                            ">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </td>

                                    </tr>
                                   
                                } 
                            </tbody>
                        </table>
                    }
                    <!-- End Table with stripped rows -->
                    
                </div>
  </div>

            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            @if (TempData["Success"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["Success"]',
                        showConfirmButton: false,
                        timer: 2000
                    });
                </script>
            }

            @if (TempData["Error"] != null)
            {
                <script>
                    Swal.fire({
                        icon: 'error',
                        title: 'Delete Failed',
                        text: '@TempData["Error"]'
                    });
                </script>
            }
 