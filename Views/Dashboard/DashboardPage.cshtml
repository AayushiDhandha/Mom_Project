@* new    think   *@

@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
        background-color: #f4f6f9;
        }

        .card {
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        }

        .card h2 {
        font-weight: bold;
        }

        .card-icon {
        position: absolute;
        top: 15px;
        right: 15px;
        font-size: 2rem;
        opacity: 0.2;
        }

        canvas {
        max-height: 350px;
        }

        /* Scroll for many labels */
        .chart-container {
        overflow-x: auto;
        }
    </style>
</head>

<body>


    <!-- Page Title -->
    <div class="mb-3">
        <h3 class="fw-bold mb-1">Dashboard</h3>
        <p class="text-muted">Meeting management overview and analytics</p>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex justify-content-end gap-3 mb-4">
        <a href="#" class="text-decoration-none text-primary">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </a>
        <button class="btn btn-success px-3">
            <i class="bi bi-download me-1"></i> Export Report
        </button>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="stat-card border-purple">
                <div class="icon purple">
                    <i class="bi bi-calendar-event"></i>
                </div>
                <h2>@ViewBag.TotalMeetings</h2>
                <p class="label">TOTAL MEETINGS</p>
                @* <span class="badge bg-success-subtle text-success">
                    ↑ 12% from last month
                </span> *@
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card border-green">
                <div class="icon green">
                    <i class="bi bi-plus-square"></i>
                </div>
                <h2>@ViewBag.UpcomingMeetings</h2>
                <p class="label">UPCOMING</p>
                @* <span class="badge bg-success-subtle text-success">
                    ↑ 8% from last week
                </span> *@
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card border-blue">
                <div class="icon blue">
                    <i class="bi bi-check-circle"></i>
                </div>
                <h2>@ViewBag.CompletedMeetings</h2>
                <p class="label">COMPLETED</p>
                @* <span class="badge bg-success-subtle text-success">
                    ↑ 15% completion rate
                </span> *@
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card border-orange">
                <div class="icon orange">
                    <i class="bi bi-x-circle"></i>
                </div>
                <h2>@ViewBag.CancelledMeetings</h2>
                <p class="label">CANCELLED</p>
                @* <span class="badge bg-danger-subtle text-danger">
                    ↓ 3% cancellation rate
                </span> *@
            </div>
        </div>

    </div>

        <!-- 📊 CHARTS -->
        <div class="row">

            <div class="col-md-6 mb-3 chart-container">
                <div class="card shadow">
                    <div class="card-body">
                        <h5>Meeting Type Chart</h5>
                        <canvas id="typeChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3 chart-container">
                <div class="card shadow">
                    <div class="card-body">
                        <h5>Department Chart</h5>
                        <canvas id="deptChart"></canvas>
                    </div>
                </div>
            </div>

        </div>

    </div>

    <!-- 🔧 SCRIPT SECTION -->
    <script>
        // Safely parse JSON from ViewBag
        var typeLabels = @Html.Raw(Json.Serialize(ViewBag.TypeNames ?? new List<string>()));
        var typeData = @Html.Raw(Json.Serialize(ViewBag.TypeCounts ?? new List<int>()));

        var deptLabels = @Html.Raw(Json.Serialize(ViewBag.DeptNames ?? new List<string>()));
        var deptData = @Html.Raw(Json.Serialize(ViewBag.DeptCounts ?? new List<int>()));

        // 📊 Bar Chart - Meeting Type
        new Chart(document.getElementById("typeChart"), {
        type: 'bar',
        data: {
        labels: typeLabels,
        datasets: [{
        label: 'Meetings',
        data: typeData,
        backgroundColor: '#007bff',
        borderRadius: 5
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: {
        display: true,
        position: 'top'
        },
        tooltip: {
        enabled: true,
        mode: 'index',
        intersect: false
        }
        },
        scales: {
        x: { beginAtZero: true },
        y: { beginAtZero: true }
        }
        }
        });

        // 🥧 Pie Chart - Department
        new Chart(document.getElementById("deptChart"), {
        type: 'pie',
        data: {
        labels: deptLabels,
        datasets: [{
        data: deptData,
        backgroundColor: [
        '#ff6384',
        '#36a2eb',
        '#ffce56',
        '#28a745',
        '#6f42c1',
        '#fd7e14',
        '#20c997'
        ]
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: {
        display: true,
        position: 'bottom'
        },
        tooltip: {
        enabled: true
        }
        }
        }
        });
    </script>

</body>
</html>
